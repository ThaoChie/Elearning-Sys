          <mxGeometry x="700" y="40" width="100" height="600" as="geometry" />
        </mxCell>
        <mxCell id="se1" value="1. POST /login (email, pwd)" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=vertical;curved=0;rounded=0;" edge="1" parent="1" source="s1" target="s2" y="100">
