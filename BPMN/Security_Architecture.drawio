        <mxCell id="se2" value="2. Validate Request" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=vertical;curved=0;rounded=0;" edge="1" parent="1" source="s2" target="s3" y="130">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="se3" value="3. Check User &amp; Lockout" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=vertical;curved=0;rounded=0;" edge="1" parent="1" source="s3" target="s4" y="160">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="se4" value="4. Argon2id Hash Check" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=vertical;curved=0;rounded=0;" edge="1" parent="1" source="s4" target="s3" y="190">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="se5" value="5. Record Success / Reset Lock" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=vertical;curved=0;rounded=0;" edge="1" parent="1" source="s3" target="s4" y="220">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="se6" value="6. Generate JWT &amp; RefreshToken" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=vertical;curved=0;rounded=0;" edge="1" parent="1" source="s3" target="s3" y="260">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="se7" value="7. Return Tokens" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;edgeStyle=elbowEdgeStyle;elbow=vertical;curved=0;rounded=0;" edge="1" parent="1" source="s3" target="s2" y="290">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="se8" value="8. HTTP 200 OK (Tokens)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;edgeStyle=elbowEdgeStyle;elbow=vertical;curved=0;rounded=0;" edge="1" parent="1" source="s2" target="s1" y="320">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="se9" value="9. POST /refresh" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=vertical;curved=0;rounded=0;" edge="1" parent="1" source="s1" target="s2" y="380">
          <mxGeometry relative="1" as="geometry" />
