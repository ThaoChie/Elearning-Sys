        <!-- ══ SECTION A: Upload Phase ══ -->
        <mxCell id="sec_a" value="SECTION A — Instructor Uploads Video"
          style="text;html=1;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="50" y="120" width="400" height="20" as="geometry"/></mxCell>

        <mxCell id="d1" value="Upload Lecture Video"                                   style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120" y="152" as="sourcePoint"/><mxPoint x="330" y="152" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="d2" value="POST /api/courses/{id}/lectures {file}"                  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="330" y="192" as="sourcePoint"/><mxPoint x="560" y="192" as="targetPoint"/></mxGeometry></mxCell>

        <!-- self-call: Validate MIME on Controller -->
        <mxCell id="d3" value="Validate MIME (magic bytes)"                             style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="232" as="sourcePoint"/>
            <mxPoint x="560" y="272" as="targetPoint"/>
            <Array as="points"><mxPoint x="622" y="232"/><mxPoint x="622" y="272"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- self-call: Generate UUID -->
        <mxCell id="d4" value="Generate UUID storage key"                               style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="312" as="sourcePoint"/>
            <mxPoint x="560" y="352" as="targetPoint"/>
            <Array as="points"><mxPoint x="622" y="312"/><mxPoint x="622" y="352"/></Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="d5"  value="PutObject(UUID, videoBytes)"                            style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="560" y="392" as="sourcePoint"/><mxPoint x="790" y="392" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="d5r" value="OK"                                                     style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="790" y="432" as="sourcePoint"/><mxPoint x="560" y="432" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="d6"  value="INSERT Lecture {VideoPath=UUID}"                        style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="560" y="472" as="sourcePoint"/><mxPoint x="1020" y="472" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="d6r" value="201 Created {lectureId}"                                style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="560" y="512" as="sourcePoint"/><mxPoint x="120" y="512" as="targetPoint"/></mxGeometry></mxCell>

        <!-- ══ SECTION B: Student Requests Signed URL ══ -->
        <mxCell id="sec_b" value="SECTION B — Student Requests Signed URL"
          style="text;html=1;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="50" y="555" width="600" height="20" as="geometry"/></mxCell>

        <mxCell id="d7"   value="Click Lecture → play video"                            style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1250" y="585" as="sourcePoint"/><mxPoint x="1510" y="585" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="d8"   value="GET /api/videos/signed-url?videoPath={UUID}"           style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1510" y="625" as="sourcePoint"/><mxPoint x="560" y="625" as="targetPoint"/></mxGeometry></mxCell>

        <!-- self-call: Extract UserId -->
        <mxCell id="d9"   value="Extract UserId from JWT Claims"                        style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="665" as="sourcePoint"/>
            <mxPoint x="560" y="705" as="targetPoint"/>
            <Array as="points"><mxPoint x="622" y="665"/><mxPoint x="622" y="705"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- self-call: HMAC-SHA256 sign URL -->
        <mxCell id="d10"  value="HMAC-SHA256({videoPath}:{userId}:{expires})"           style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="745" as="sourcePoint"/>
            <mxPoint x="560" y="785" as="targetPoint"/>
            <Array as="points"><mxPoint x="622" y="745"/><mxPoint x="622" y="785"/></Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="d10r" value="200 OK: {signedUrl, expiresAt (TTL 4h)}"               style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="560" y="825" as="sourcePoint"/><mxPoint x="1510" y="825" as="targetPoint"/></mxGeometry></mxCell>

        <!-- ══ SECTION C: Player + Watermark ══ -->
        <mxCell id="sec_c" value="SECTION C — SecureVideoPlayer + Canvas Watermark"
          style="text;html=1;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="50" y="865" width="700" height="20" as="geometry"/></mxCell>

        <!-- Player self-calls — U-shape right side of SecureVideoPlayer -->
        <mxCell id="d11" value="Render &lt;video src=signedUrl&gt;"                     style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1510" y="895" as="sourcePoint"/>
            <mxPoint x="1510" y="935" as="targetPoint"/>
            <Array as="points"><mxPoint x="1572" y="895"/><mxPoint x="1572" y="935"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="d12" value="Draw &lt;canvas&gt; overlay (pointer-events:none)"      style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1510" y="975" as="sourcePoint"/>
            <mxPoint x="1510" y="1015" as="targetPoint"/>
            <Array as="points"><mxPoint x="1572" y="975"/><mxPoint x="1572" y="1015"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="d13" value="drawText '{userId}·{ts}' rotate(-45°) rgba(255,255,255,0.18)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1510" y="1055" as="sourcePoint"/>
            <mxPoint x="1510" y="1095" as="targetPoint"/>
            <Array as="points"><mxPoint x="1572" y="1055"/><mxPoint x="1572" y="1095"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="d14" value="Block: contextmenu, dragstart, download, PiP"           style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1510" y="1135" as="sourcePoint"/>
            <mxPoint x="1510" y="1175" as="targetPoint"/>
            <Array as="points"><mxPoint x="1572" y="1135"/><mxPoint x="1572" y="1175"/></Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ═══════════════════════════════════════════════════════════
       TAB 3 – ACTIVITY DIAGRAM: ASSESSMENT DESIGN
       ═══════════════════════════════════════════════════════════ -->
  <diagram name="Tab3 – Activity (Assessment Design)" id="tab3-activity-assess">
    <mxGraphModel dx="1400" dy="960" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="1100" pageHeight="1300"
                  math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="ad_title" value="Activity Diagram — Instructor Assessment Design (Quiz / Assignment)"
          style="text;html=1;fontSize=15;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="100" y="10" width="850" height="28" as="geometry"/></mxCell>

        <!-- Swimlane: Instructor -->
        <mxCell id="asl_inst" value="Instructor"
          style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=13;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="40" y="50" width="380" height="1200" as="geometry"/></mxCell>

        <!-- Swimlane: System -->
        <mxCell id="asl_sys" value="System / Backend"
          style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=13;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="440" y="50" width="380" height="1200" as="geometry"/></mxCell>

        <!-- Instructor Lane -->
        <mxCell id="ad_s" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="asl_inst"><mxGeometry x="168" y="30" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="ad1" value="Navigate to Course → Assessments Section"    style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="asl_inst"><mxGeometry x="90" y="85" width="185" height="50" as="geometry"/></mxCell>
        <mxCell id="ad_d1" value="Assessment&#xa;Type?"                       style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="asl_inst"><mxGeometry x="120" y="165" width="120" height="80" as="geometry"/></mxCell>
        <!-- Quiz branch -->
        <mxCell id="ad_q1" value="Input Quiz Title"                           style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="asl_inst"><mxGeometry x="20" y="295" width="150" height="44" as="geometry"/></mxCell>
        <mxCell id="ad_q2" value="Set TimeLimitMin (&gt;0)"                  style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="asl_inst"><mxGeometry x="20" y="365" width="150" height="44" as="geometry"/></mxCell>
        <mxCell id="ad_q3" value="Add Question (Content, Order)"              style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="asl_inst"><mxGeometry x="20" y="435" width="150" height="44" as="geometry"/></mxCell>
        <mxCell id="ad_q4" value="Add Answers (Mark IsCorrect)"               style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="asl_inst"><mxGeometry x="20" y="505" width="150" height="44" as="geometry"/></mxCell>
        <mxCell id="ad_qd" value="More&#xa;Questions?"                        style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontColor=#000000;" vertex="1" parent="asl_inst"><mxGeometry x="35" y="575" width="110" height="70" as="geometry"/></mxCell>
        <!-- Assignment branch -->
        <mxCell id="ad_a1" value="Input Assignment Title + Description"       style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="asl_inst"><mxGeometry x="205" y="295" width="155" height="50" as="geometry"/></mxCell>
        <mxCell id="ad_a2" value="Set DueAt Deadline (UTC)"                  style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="asl_inst"><mxGeometry x="205" y="365" width="155" height="44" as="geometry"/></mxCell>
        <!-- Merge -->
        <mxCell id="ad_merge" value="" style="rhombus;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="asl_inst"><mxGeometry x="160" y="680" width="40" height="40" as="geometry"/></mxCell>
        <mxCell id="ad_save" value="Submit to Backend (Save Assessment)"      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="asl_inst"><mxGeometry x="100" y="750" width="180" height="50" as="geometry"/></mxCell>
        <mxCell id="ad_end" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;shape=doubleEllipse;" vertex="1" parent="asl_inst"><mxGeometry x="168" y="830" width="28" height="28" as="geometry"/></mxCell>

        <!-- System Lane -->
        <mxCell id="sys_validate" value="Validate Input (FluentValidation)"   style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="asl_sys"><mxGeometry x="90" y="750" width="190" height="50" as="geometry"/></mxCell>
        <mxCell id="sys_d_valid"  value="Valid?"                               style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="asl_sys"><mxGeometry x="120" y="830" width="120" height="70" as="geometry"/></mxCell>
        <mxCell id="sys_err_v"    value="Return 400&#xa;validation_error"      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=2;fontColor=#000000;" vertex="1" parent="asl_sys"><mxGeometry x="280" y="848" width="80" height="44" as="geometry"/></mxCell>
        <mxCell id="sys_shuffle"  value="Shuffle Questions server-side&#xa;(Quiz only — IsCorrect NOT exposed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="asl_sys"><mxGeometry x="90" y="930" width="190" height="60" as="geometry"/></mxCell>
        <mxCell id="sys_persist"  value="INSERT to DB (Quiz / Assignment / Questions)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="asl_sys"><mxGeometry x="90" y="1020" width="190" height="50" as="geometry"/></mxCell>
        <mxCell id="sys_notif"    value="Fire Push Notification to Enrolled Students" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="asl_sys"><mxGeometry x="90" y="1100" width="190" height="50" as="geometry"/></mxCell>

        <!-- Instructor edges -->
        <mxCell id="ade1"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_inst" source="ad_s"    target="ad1"    ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ade2"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_inst" source="ad1"     target="ad_d1"  ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ade3"  value="Quiz"       style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="asl_inst" source="ad_d1" target="ad_q1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ade4"  value="Assignment" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="asl_inst" source="ad_d1" target="ad_a1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ade5"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_inst" source="ad_q1"   target="ad_q2"  ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ade6"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_inst" source="ad_q2"   target="ad_q3"  ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ade7"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_inst" source="ad_q3"   target="ad_q4"  ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ade8"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_inst" source="ad_q4"   target="ad_qd"  ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ade9"  value="Yes" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="asl_inst" source="ad_qd" target="ad_q3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="15" y="610"/><mxPoint x="15" y="457"/></Array></mxGeometry></mxCell>
        <mxCell id="ade10" value="No"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="asl_inst" source="ad_qd" target="ad_merge"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ade11" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_inst" source="ad_a1"   target="ad_a2"  ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ade12" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_inst" source="ad_a2"   target="ad_merge"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ade13" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_inst" source="ad_merge" target="ad_save"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ade14" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_inst" source="ad_save"  target="ad_end" ><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- System edges -->
        <mxCell id="sye1" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_sys" source="sys_validate" target="sys_d_valid" ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sye2" value="Invalid" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="asl_sys" source="sys_d_valid" target="sys_err_v" ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sye3" value="Valid"   style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="asl_sys" source="sys_d_valid" target="sys_shuffle"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sye4" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_sys" source="sys_shuffle"  target="sys_persist" ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="sye5" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="asl_sys" source="sys_persist"  target="sys_notif"   ><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Cross-lane -->
        <mxCell id="cx_1" value="submit" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="775" as="sourcePoint"/><mxPoint x="530" y="775" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="cx_2" value="201 OK" style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="530" y="1070" as="sourcePoint"/><mxPoint x="280" y="858" as="targetPoint"/></mxGeometry></mxCell>

      </root>
    </mxGraphModel>
  </diagram>

</mxfile>
