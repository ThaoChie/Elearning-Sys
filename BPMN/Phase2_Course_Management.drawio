          vertex="1" parent="sw_inst"><mxGeometry x="100" y="990" width="180" height="44" as="geometry"/></mxCell>

        <mxCell id="cc_end" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;shape=doubleEllipse;" vertex="1" parent="sw_inst"><mxGeometry x="170" y="1060" width="28" height="28" as="geometry"/></mxCell>

        <!-- ── System Lane ── -->
