          vertex="1" parent="sw_minio"><mxGeometry x="40" y="860" width="180" height="44" as="geometry"/></mxCell>

        <mxCell id="minio_ok" value="Storage ACK&#xa;(path confirmed)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=11;fontColor=#000000;"
          vertex="1" parent="sw_minio"><mxGeometry x="40" y="930" width="180" height="44" as="geometry"/></mxCell>

        <!-- ── Edges: Instructor Lane ── -->
        <mxCell id="e_s1"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc_s"    target="cc1"    ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_s2"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc1"     target="cc2"    ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_s3"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc2"     target="cc3"    ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_s4"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc3"     target="cc4"    ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_s5"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc4"     target="cc5"    ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_s6"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc5"     target="cc_d1"  ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d1l" value="Lecture" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sw_inst" source="cc_d1" target="cc_l1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d1q" value="Quiz"    style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sw_inst" source="cc_d1" target="cc_q1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_l1"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc_l1" target="cc_l2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_q1"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc_q1" target="cc_q2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_l2m" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc_l2"  target="cc_merge"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_q2m" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc_q2"  target="cc_merge"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_md2" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc_merge" target="cc_d2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d2y" value="Yes" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sw_inst" source="cc_d2" target="cc5"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="30" y="825"/><mxPoint x="30" y="397"/></Array></mxGeometry></mxCell>
        <mxCell id="e_d2n" value="No"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sw_inst" source="cc_d2" target="cc_d3"><mxGeometry relative="1" as="geometry"/></mxCell>
