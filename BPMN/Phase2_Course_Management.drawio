        <mxCell id="cc_l2"  value="Select Video File (from disk)"          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="15"  y="665" width="165" height="44" as="geometry"/></mxCell>
        <!-- Branch: Quiz -->
        <mxCell id="cc_q1"  value="Input Quiz Title + TimeLimitMin"        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="215" y="590" width="165" height="44" as="geometry"/></mxCell>
        <mxCell id="cc_q2"  value="Add Questions + Answers (IsCorrect hidden)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="215" y="665" width="165" height="44" as="geometry"/></mxCell>
        <!-- Merge -->
        <mxCell id="cc_merge" value="" style="rhombus;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="183" y="750" width="40" height="40" as="geometry"/></mxCell>
        <!-- Add more? -->
        <mxCell id="cc_d2"  value="Add More&#xa;Content?"                 style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="140" y="825" width="120" height="70" as="geometry"/></mxCell>
        <!-- Publish? -->
        <mxCell id="cc_d3"  value="Publish&#xa;Course?"                   style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="140" y="930" width="120" height="70" as="geometry"/></mxCell>
        <mxCell id="cc_pub" value="Set IsPublished = true"                 style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="110" y="1035" width="180" height="44" as="geometry"/></mxCell>
        <mxCell id="cc_end" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;shape=doubleEllipse;" vertex="1" parent="sw_inst"><mxGeometry x="183" y="1110" width="28" height="28" as="geometry"/></mxCell>

        <!-- ── System Lane ── -->
        <mxCell id="sys_v1" value="Validate MIME Type (magic bytes)"        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontColor=#000000;" vertex="1" parent="sw_sys"><mxGeometry x="110" y="665" width="180" height="50" as="geometry"/></mxCell>
        <mxCell id="sys_d_mime" value="MIME&#xa;Valid?"                     style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontColor=#000000;" vertex="1" parent="sw_sys"><mxGeometry x="145" y="745" width="100" height="70" as="geometry"/></mxCell>
        <mxCell id="sys_err"    value="Return 422&#xa;invalid_mime_type"   style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=2;fontColor=#000000;" vertex="1" parent="sw_sys"><mxGeometry x="285" y="762" width="80" height="44" as="geometry"/></mxCell>
        <mxCell id="sys_uuid"   value="Generate UUID VideoPath key"        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontColor=#000000;" vertex="1" parent="sw_sys"><mxGeometry x="110" y="850" width="180" height="44" as="geometry"/></mxCell>
        <mxCell id="sys_save"   value="Persist Lecture.VideoPath = UUID"   style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontColor=#000000;" vertex="1" parent="sw_sys"><mxGeometry x="110" y="1000" width="180" height="50" as="geometry"/></mxCell>

        <!-- ── MinIO Lane ── -->
