  <!-- ═══════════════════════════════════════════════════════════
       TAB 2 – SEQUENCE DIAGRAM: VIDEO DRM
       Spread Y-spacing x2; self-calls U-shape; no crowding
       ═══════════════════════════════════════════════════════════ -->
  <diagram name="Tab2 – Sequence (Video DRM)" id="tab2-seq-drm">
    <mxGraphModel dx="1600" dy="960" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="1700" pageHeight="1250"
                  math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="drm_title" value="Sequence Diagram — Video DRM: MinIO Upload + Signed URL + Canvas Watermark"
          style="text;html=1;fontSize=15;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1450" height="28" as="geometry"/>
        </mxCell>

        <!-- PARTICIPANTS — evenly spaced, wider gaps -->
        <mxCell id="p_inst"    value="Instructor"                    style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="50"   y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="p_fe_inst" value="Frontend&#xa;(Instructor)"     style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="260"  y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="p_api2"    value="VideoController&#xa;(API)"     style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="490"  y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="p_minio2"  value="MinIO&#xa;(Object Store)"      style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="720"  y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="p_db2"     value="SQL Server&#xa;(DB)"           style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="950"  y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="p_student" value="Student"                       style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="1180" y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="p_fe_stu"  value="SecureVideoPlayer&#xa;(Frontend)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="1440" y="55" width="140" height="44" as="geometry"/></mxCell>

