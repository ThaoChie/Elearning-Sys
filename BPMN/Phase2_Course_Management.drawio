          vertex="1" parent="sw_inst"><mxGeometry x="20" y="640" width="155" height="44" as="geometry"/></mxCell>

        <!-- Branch: Quiz -->
        <mxCell id="cc_q1" value="Input Quiz Title&#xa;+ TimeLimitMin"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=11;fontColor=#000000;"
          vertex="1" parent="sw_inst"><mxGeometry x="205" y="570" width="155" height="44" as="geometry"/></mxCell>

        <mxCell id="cc_q2" value="Add Questions&#xa;+ Answers (IsCorrect hidden)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=11;fontColor=#000000;"
          vertex="1" parent="sw_inst"><mxGeometry x="205" y="640" width="155" height="44" as="geometry"/></mxCell>

        <!-- Merge point -->
        <mxCell id="cc_merge" value=""
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;"
          vertex="1" parent="sw_inst"><mxGeometry x="165" y="720" width="40" height="40" as="geometry"/></mxCell>

        <!-- Add more? -->
        <mxCell id="cc_d2" value="Add More&#xa;Content?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sw_inst"><mxGeometry x="125" y="790" width="120" height="70" as="geometry"/></mxCell>

        <!-- Publish decision -->
        <mxCell id="cc_d3" value="Publish&#xa;Course?"
