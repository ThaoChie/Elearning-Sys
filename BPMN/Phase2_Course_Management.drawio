<mxfile host="app.diagrams.net" modified="2026-06-17" agent="draw.io" version="24.0.0" type="device">

<!-- ============================================================
     PHASE 2 — COURSE MANAGEMENT
     Tab 1 : Flow Diagram – Course Creation (aligned)
     Tab 2 : Sequence Diagram – Video DRM (spread, no crowding)
     Tab 3 : Activity Diagram – Assessment Design
     Style  : Blueprint · strokeWidth=1.5 · Orthogonal · Max spacing
     ============================================================ -->

  <!-- ═══════════════════════════════════════════════════════════
       TAB 1 – FLOW DIAGRAM: COURSE CREATION
       Aligned on X and Y axis; swimlanes gapped properly
       ═══════════════════════════════════════════════════════════ -->
  <diagram name="Tab1 – Flow (Course Creation)" id="tab1-flow-course">
    <mxGraphModel dx="1400" dy="960" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="1400" pageHeight="1500"
                  math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="cc_title" value="Flow Diagram — Instructor Course Creation &amp; Publishing"
          style="text;html=1;fontSize=15;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="200" y="10" width="900" height="28" as="geometry"/></mxCell>

        <!-- Swimlane: Instructor -->
        <mxCell id="sw_inst" value="Instructor"
          style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=13;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="40"  y="50" width="400" height="1380" as="geometry"/></mxCell>

        <!-- Swimlane: System / Backend -->
        <mxCell id="sw_sys" value="System / Backend"
          style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=13;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="460" y="50" width="400" height="1380" as="geometry"/></mxCell>

        <!-- Swimlane: Storage (MinIO) -->
        <mxCell id="sw_minio" value="Storage (MinIO)"
          style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=13;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="880" y="50" width="300" height="1380" as="geometry"/></mxCell>

        <!-- ── Instructor Lane ── -->
        <mxCell id="cc_s"   value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="183" y="30" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="cc1"    value="Login (JWT Auth)"                       style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="110" y="80"  width="180" height="44" as="geometry"/></mxCell>
        <mxCell id="cc2"    value="Click 'Create Course'"                  style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="110" y="155" width="180" height="44" as="geometry"/></mxCell>
        <mxCell id="cc3"    value="Input: Title, Description,&#xa;Upload Thumbnail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="110" y="230" width="180" height="55" as="geometry"/></mxCell>
        <mxCell id="cc4"    value="Save Course (IsPublished = false)"      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="110" y="315" width="180" height="44" as="geometry"/></mxCell>
        <mxCell id="cc5"    value="Add Module (Title, Order)"              style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="110" y="390" width="180" height="44" as="geometry"/></mxCell>
        <!-- Decision: Content type -->
        <mxCell id="cc_d1"  value="Content&#xa;Type?"                     style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="140" y="465" width="120" height="80" as="geometry"/></mxCell>
        <!-- Branch: Lecture -->
