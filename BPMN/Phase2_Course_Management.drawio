        <mxCell id="minio_ok"  value="Storage ACK (path confirmed)"        style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontColor=#000000;" vertex="1" parent="sw_minio"><mxGeometry x="55" y="970" width="180" height="44" as="geometry"/></mxCell>

        <!-- ── Instructor edges ── -->
        <mxCell id="e_s1"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc_s"    target="cc1"     ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_s2"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc1"     target="cc2"     ><mxGeometry relative="1" as="geometry"/></mxCell>
