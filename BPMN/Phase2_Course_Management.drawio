<mxfile host="app.diagrams.net" modified="2026-06-17" agent="draw.io" version="24.0.0" type="device">

<!-- ============================================================
     PHASE 2 — COURSE MANAGEMENT
     Tab 1 : Flow Diagram – Course Creation
     Tab 2 : Sequence Diagram – Video DRM (MinIO + Signed URL + Watermark)
     Tab 3 : Activity Diagram – Assessment Design
     Style  : Minimalist · Monochrome · Orthogonal edges
     ============================================================ -->

  <!-- ═══════════════════════════════════════════════════════════
       TAB 1 – FLOW DIAGRAM: COURSE CREATION
       ═══════════════════════════════════════════════════════════ -->
  <diagram name="Tab1 – Flow (Course Creation)" id="tab1-flow-course">
    <mxGraphModel dx="1400" dy="960" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="1400" pageHeight="1400"
                  math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="cc_title" value="Flow Diagram — Instructor Course Creation &amp; Publishing"
          style="text;html=1;fontSize=15;fontStyle=1;align=center;
                 fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="900" height="28" as="geometry"/>
        </mxCell>

        <!-- Swimlane: Instructor -->
        <mxCell id="sw_inst" value="Instructor"
          style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#000000;
                 fontStyle=1;fontSize=13;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="380" height="1280" as="geometry"/>
        </mxCell>

        <!-- Swimlane: System / Backend -->
        <mxCell id="sw_sys" value="System / Backend"
          style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#000000;
                 fontStyle=1;fontSize=13;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="440" y="50" width="380" height="1280" as="geometry"/>
        </mxCell>

        <!-- Swimlane: Storage (MinIO) -->
        <mxCell id="sw_minio" value="Storage (MinIO)"
          style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#000000;
                 fontStyle=1;fontSize=13;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="840" y="50" width="280" height="1280" as="geometry"/>
        </mxCell>

        <!-- ── Instructor Lane ── -->
        <mxCell id="cc_s" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="sw_inst"><mxGeometry x="170" y="30" width="28" height="28" as="geometry"/></mxCell>

        <mxCell id="cc1" value="Login (JWT Auth)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sw_inst"><mxGeometry x="100" y="85" width="180" height="44" as="geometry"/></mxCell>

        <mxCell id="cc2" value="Click 'Create Course'"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sw_inst"><mxGeometry x="100" y="155" width="180" height="44" as="geometry"/></mxCell>

        <mxCell id="cc3" value="Input: Title, Description,&#xa;Upload Thumbnail"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sw_inst"><mxGeometry x="100" y="225" width="180" height="50" as="geometry"/></mxCell>

        <mxCell id="cc4" value="Save Course&#xa;(IsPublished = false)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sw_inst"><mxGeometry x="100" y="305" width="180" height="44" as="geometry"/></mxCell>

        <mxCell id="cc5" value="Add Module (Title, Order)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sw_inst"><mxGeometry x="100" y="375" width="180" height="44" as="geometry"/></mxCell>

        <!-- Decision: Content type -->
        <mxCell id="cc_d1" value="Content&#xa;Type?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sw_inst"><mxGeometry x="125" y="445" width="120" height="80" as="geometry"/></mxCell>

        <!-- Branch: Lecture -->
        <mxCell id="cc_l1" value="Input Lecture Title&#xa;+ Set Order"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=11;fontColor=#000000;"
          vertex="1" parent="sw_inst"><mxGeometry x="20" y="570" width="155" height="44" as="geometry"/></mxCell>

        <mxCell id="cc_l2" value="Select Video File&#xa;(from disk)"
