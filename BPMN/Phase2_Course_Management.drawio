          vertex="1" parent="sw_sys"><mxGeometry x="90" y="950" width="180" height="50" as="geometry"/></mxCell>

        <!-- ── MinIO Lane ── -->
        <mxCell id="minio_up" value="Upload Video File&#xa;to MinIO bucket"
