        <mxCell id="e_s6"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sw_inst" source="cc5"     target="cc_d1"   ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_d1l" value="Lecture" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sw_inst" source="cc_d1" target="cc_l1"><mxGeometry relative="1" as="geometry"/></mxCell>
