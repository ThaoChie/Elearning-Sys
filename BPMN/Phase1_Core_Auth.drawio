  <!-- ═══════════════════════════════════════════════════════════
       TAB 4 — SEQUENCE DIAGRAM: AUTH FLOW (Argon2 + 2FA)
       Uses «opt» for 2FA optional step
       Uses «alt» for valid/invalid password check
       Self-calls: orthogonal U-shape
       ═══════════════════════════════════════════════════════════ -->
  <diagram name="Tab4 – Sequence (Auth Flow)" id="tab4-seq-auth">
    <mxGraphModel dx="1600" dy="960" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="1600" pageHeight="1400"
                  math="0" shadow="0">
