          vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1350" height="28" as="geometry"/>
        </mxCell>

        <!-- PARTICIPANTS -->
        <mxCell id="ap1" value="Client&#xa;(Browser)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="60"   y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="ap2" value="Auth&#xa;Controller"  style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="290"  y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="ap3" value="UserService&#xa;(Domain)"   style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="520"  y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="ap4" value="DB&#xa;(SQL Server)"  style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="750"  y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="ap5" value="TokenService"         style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="980"  y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="ap6" value="AuditLog&#xa;Middleware" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="1210" y="55" width="140" height="44" as="geometry"/></mxCell>

        <!-- LIFELINES -->
        <mxCell id="al1" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130"  y="99" as="sourcePoint"/><mxPoint x="130"  y="1370" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="al2" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="360"  y="99" as="sourcePoint"/><mxPoint x="360"  y="1370" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="al3" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="590"  y="99" as="sourcePoint"/><mxPoint x="590"  y="1370" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="al4" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="820"  y="99" as="sourcePoint"/><mxPoint x="820"  y="1370" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="al5" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1050" y="99" as="sourcePoint"/><mxPoint x="1050" y="1370" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="al6" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1280" y="99" as="sourcePoint"/><mxPoint x="1280" y="1370" as="targetPoint"/></mxGeometry></mxCell>

        <!-- PHASE 1: Login Request -->
        <mxCell id="as1_lbl" value="PHASE 1 — Login Request"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="60" y="120" width="300" height="18" as="geometry"/></mxCell>

        <mxCell id="am1" value="POST /api/auth/login {email, password}"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="130" y="150" as="sourcePoint"/><mxPoint x="360" y="150" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="am2" value="ValidateRequest (FluentValidation)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="360" y="188" as="sourcePoint"/>
            <mxPoint x="360" y="228" as="targetPoint"/>
            <Array as="points"><mxPoint x="420" y="188"/><mxPoint x="420" y="228"/></Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="am3" value="FindByEmail(email)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="360" y="258" as="sourcePoint"/><mxPoint x="590" y="258" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="am4" value="SELECT * FROM Users WHERE Email={email}"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="590" y="290" as="sourcePoint"/><mxPoint x="820" y="290" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="am4r" value="User {PasswordHash, TwoFactorEnabled, LockoutEnd, ...}"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="820" y="318" as="sourcePoint"/><mxPoint x="590" y="318" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PHASE 2: Password + Lockout Check — UML «alt» fragment -->
        <mxCell id="as2_lbl" value="PHASE 2 — Password Verification (Argon2id) + Lockout Check"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="60" y="355" width="600" height="18" as="geometry"/></mxCell>

        <!-- alt frame: x=340 y=375, w=680, h=280 -->
        <mxCell id="auth_alt" value="alt"
          style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;
                 fillColor=none;strokeColor=#000000;strokeWidth=1.5;spacingLeft=6;spacingTop=2;"
          vertex="1" parent="1"><mxGeometry x="340" y="375" width="680" height="280" as="geometry"/></mxCell>

        <!-- alt guard 1 -->
        <mxCell id="auth_g1" value="[IsLockedOut() == true]"
          style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="350" y="380" width="200" height="18" as="geometry"/></mxCell>

        <mxCell id="am5a" value="401 Unauthorized: account_locked"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="590" y="415" as="sourcePoint"/><mxPoint x="130" y="415" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- alt divider 1 -->
        <mxCell id="auth_div1" value="" style="endArrow=none;dashed=1;dashPattern=6 3;html=1;strokeColor=#000000;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="340" y="445" as="sourcePoint"/><mxPoint x="1020" y="445" as="targetPoint"/></mxGeometry>
        </mxCell>
        <!-- alt guard 2 -->
        <mxCell id="auth_g2" value="[Argon2id.Verify(password, hash) == false]"
          style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="350" y="450" width="310" height="18" as="geometry"/></mxCell>

        <!-- self-call: RecordFailedLogin on UserService -->
        <mxCell id="am5b_sc" value="RecordFailedLogin() → FailedCount++&#xa;[if ≥5 → LockoutEnd=UtcNow+15min]"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="590" y="480" as="sourcePoint"/>
            <mxPoint x="590" y="520" as="targetPoint"/>
            <Array as="points"><mxPoint x="650" y="480"/><mxPoint x="650" y="520"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="am5b" value="SaveChanges()"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="590" y="540" as="sourcePoint"/><mxPoint x="820" y="540" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="am5b_r" value="401 Unauthorized: invalid_credentials"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="590" y="570" as="sourcePoint"/><mxPoint x="130" y="570" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- alt divider 2 -->
        <mxCell id="auth_div2" value="" style="endArrow=none;dashed=1;dashPattern=6 3;html=1;strokeColor=#000000;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="340" y="600" as="sourcePoint"/><mxPoint x="1020" y="600" as="targetPoint"/></mxGeometry>
        </mxCell>
        <!-- alt guard 3 -->
        <mxCell id="auth_g3" value="[else — credentials valid]"
          style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="350" y="605" width="220" height="18" as="geometry"/></mxCell>

        <!-- Reset FailedCount on success -->
        <mxCell id="am6_sc" value="ResetFailedLoginCount() → FailedCount=0"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="590" y="635" as="sourcePoint"/>
            <mxPoint x="590" y="665" as="targetPoint"/>
            <Array as="points"><mxPoint x="650" y="635"/><mxPoint x="650" y="665"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- PHASE 3: 2FA Check — UML «opt» fragment -->
        <mxCell id="as3_lbl" value="PHASE 3 — Optional 2FA TOTP Challenge"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="60" y="700" width="500" height="18" as="geometry"/></mxCell>

        <!-- opt frame: x=340 y=718, w=680, h=185 -->
        <mxCell id="auth_opt" value="opt"
          style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;
                 fillColor=none;strokeColor=#000000;strokeWidth=1.5;spacingLeft=6;spacingTop=2;"
          vertex="1" parent="1"><mxGeometry x="340" y="718" width="680" height="185" as="geometry"/></mxCell>

        <mxCell id="auth_optg" value="[TwoFactorEnabled == true]"
          style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="350" y="723" width="220" height="18" as="geometry"/></mxCell>

        <mxCell id="am7" value="200 OK: {requiresTwoFactor: true, tempToken}"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="590" y="758" as="sourcePoint"/><mxPoint x="130" y="758" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="am8" value="POST /api/auth/totp-verify {tempToken, totpCode}"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="130" y="790" as="sourcePoint"/><mxPoint x="360" y="790" as="targetPoint"/></mxGeometry>
        </mxCell>
        <!-- self-call: ValidateTOTP -->
        <mxCell id="am9_sc" value="TOTP.Validate(secret, code, window=±30s)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="590" y="823" as="sourcePoint"/>
            <mxPoint x="590" y="863" as="targetPoint"/>
            <Array as="points"><mxPoint x="650" y="823"/><mxPoint x="650" y="863"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="am9_r" value="401 unauthorized / proceed to token issue"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="590" y="880" as="sourcePoint"/><mxPoint x="130" y="880" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PHASE 4: Issue JWT + RefreshToken -->
        <mxCell id="as4_lbl" value="PHASE 4 — Issue JWT + Rotate RefreshToken"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="60" y="930" width="500" height="18" as="geometry"/></mxCell>

        <mxCell id="am10" value="GenerateJWT(userId, role, claims, exp=15min)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="590" y="960" as="sourcePoint"/><mxPoint x="1050" y="960" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="am10r" value="accessToken (JWT)"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1050" y="988" as="sourcePoint"/><mxPoint x="590" y="988" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- self-call: SetRefreshToken on UserService -->
        <mxCell id="am11_sc" value="SetRefreshToken() → UUID32hex, exp=7d"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="590" y="1020" as="sourcePoint"/>
            <mxPoint x="590" y="1060" as="targetPoint"/>
            <Array as="points"><mxPoint x="650" y="1020"/><mxPoint x="650" y="1060"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="am12" value="UPDATE User SET RefreshToken=UUID, RefreshTokenExpiresAt=UtcNow+7d"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="590" y="1085" as="sourcePoint"/><mxPoint x="820" y="1085" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="am13" value="200 OK: {accessToken, refreshToken, expiresIn:900}"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="360" y="1120" as="sourcePoint"/><mxPoint x="130" y="1120" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- PHASE 5: AuditLog -->
        <mxCell id="as5_lbl" value="PHASE 5 — AuditMiddleware (fire-and-forget)"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="60" y="1160" width="500" height="18" as="geometry"/></mxCell>

        <mxCell id="am14" value="HMAC-SHA256(logId|ts|userId|action|ip)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;dashed=1;dashPattern=5 3;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="360" y="1190" as="sourcePoint"/><mxPoint x="1280" y="1190" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="am15" value="INSERT AuditLog {Action='POST /auth/login → 200'}"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;dashed=1;dashPattern=5 3;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1280" y="1230" as="sourcePoint"/><mxPoint x="820" y="1230" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

</mxfile>
