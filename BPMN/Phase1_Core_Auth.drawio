<!-- ============================================================
     PHASE 1 — CORE AUTH & IDENTITY
     Tab 1 : Use Case General (System Boundary)
     Tab 2 : Use Case Decomposed (<<include>> / <<extend>>)
     Tab 3 : Full System ERD
     Tab 4 : Sequence Diagram – Authentication Flow (alt/opt)
     Style  : Blueprint · White bg · Black stroke 1.5 · Orthogonal
     ============================================================ -->

  <!-- ═══════════════════════════════════════════════════════════
       TAB 1 — GENERAL USE CASE DIAGRAM
       System Boundary bao toàn bộ UC tổng quan
       Actors: Student, Instructor, Admin
       ═══════════════════════════════════════════════════════════ -->
  <diagram name="Tab1 – Use Case (General)" id="tab1-uc-general">
    <mxGraphModel dx="1400" dy="960" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="1400" pageHeight="1050"
                  math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
