<mxfile host="app.diagrams.net" modified="2026-06-17" agent="draw.io" version="24.0.0" type="device">

<!-- ============================================================
     PHASE 4 — NOTIFICATION & AUDIT LOG
     Tab 1 : Sequence Diagram – Notification + IDOR Prevention
     Tab 2 : Flow Diagram – Dual-Stream Audit Log Integrity
     Style  : Minimalist · Monochrome · Orthogonal edges
     UML    : alt/opt fragments, orthogonal self-calls, max Y-spacing
     ============================================================ -->

  <!-- ═══════════════════════════════════════════════════════════
       TAB 1 – SEQUENCE DIAGRAM: NOTIFICATION + IDOR CHECK
       Fixes: Replace rhombus IDOR decision + rounded box 403
              with proper UML «alt» combined fragment.
              Self-call (Extract jwtUserId) → orthogonal U-shape.
              Y-spacing doubled to prevent label overlap.
       ═══════════════════════════════════════════════════════════ -->
  <diagram name="Tab1 – Sequence (Notification + IDOR)" id="tab1-seq-notif">
    <mxGraphModel dx="1600" dy="960" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="1650" pageHeight="1500"
                  math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ── Title ── -->
        <mxCell id="n_title" value="Sequence Diagram — Notification System with IDOR Prevention (UML alt Fragment)"
          style="text;html=1;fontSize=15;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1400" height="28" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════
             PARTICIPANTS  (Y=55, height=44)
             X positions: 80, 300, 520, 740, 960, 1190
             Lifeline centres: 152, 372, 592, 812, 1032, 1262
        ══════════════════════════════════ -->
        <mxCell id="n_p1" value="System Event&#xa;(Trigger)"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="80"   y="55" width="144" height="44" as="geometry"/></mxCell>
        <mxCell id="n_p2" value="Notification&#xa;Service"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="300"  y="55" width="144" height="44" as="geometry"/></mxCell>
        <mxCell id="n_p3" value="DB&#xa;(Notifications)"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="520"  y="55" width="144" height="44" as="geometry"/></mxCell>
        <mxCell id="n_p4" value="User&#xa;(Any Role)"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="740"  y="55" width="144" height="44" as="geometry"/></mxCell>
        <mxCell id="n_p5" value="Notifications&#xa;Controller"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="960"  y="55" width="144" height="44" as="geometry"/></mxCell>
        <mxCell id="n_p6" value="AuditLog&#xa;Middleware"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="1190" y="55" width="144" height="44" as="geometry"/></mxCell>

        <!-- ── Lifelines ── -->
        <mxCell id="n_ll1" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="152"  y="99" as="sourcePoint"/><mxPoint x="152"  y="1450" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="n_ll2" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="372"  y="99" as="sourcePoint"/><mxPoint x="372"  y="1450" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="n_ll3" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="592"  y="99" as="sourcePoint"/><mxPoint x="592"  y="1450" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="n_ll4" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="812"  y="99" as="sourcePoint"/><mxPoint x="812"  y="1450" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="n_ll5" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1032" y="99" as="sourcePoint"/><mxPoint x="1032" y="1450" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="n_ll6" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1262" y="99" as="sourcePoint"/><mxPoint x="1262" y="1450" as="targetPoint"/></mxGeometry></mxCell>

        <!-- ═══════════════════════════════════════════════════════
             SECTION A — System Creates Notification
        ═══════════════════════════════════════════════════════ -->
        <mxCell id="n_sA" value="SECTION A — System Pushes Notification (e.g. Exam Graded, Assignment Due)"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="80" y="120" width="800" height="18" as="geometry"/></mxCell>

        <!-- A1: Event fires -->
        <mxCell id="n_m1" value="Event Fires (e.g. SubmissionGraded)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="152" y="150" as="sourcePoint"/><mxPoint x="372" y="150" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- A2: Self-call on NotificationService — orthogonal U-shape right side -->
        <mxCell id="n_m2" value="Resolve Target UserId&#xa;(from context — NOT from client)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="372" y="185" as="sourcePoint"/>
            <mxPoint x="372" y="225" as="targetPoint"/>
            <Array as="points"><mxPoint x="432" y="185"/><mxPoint x="432" y="225"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- A3: INSERT Notification -->
        <mxCell id="n_m3" value="INSERT Notification {UserId, Title, Message, IsRead=false, CreatedAt=UtcNow}"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="372" y="255" as="sourcePoint"/><mxPoint x="592" y="255" as="targetPoint"/></mxGeometry>
        </mxCell>
        <!-- A3r: return -->
        <mxCell id="n_m3r" value="notificationId"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="592" y="285" as="sourcePoint"/><mxPoint x="372" y="285" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════
             SECTION B — User Fetches Notification List
        ═══════════════════════════════════════════════════════ -->
        <mxCell id="n_sB" value="SECTION B — User Fetches Notification List"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="80" y="330" width="600" height="18" as="geometry"/></mxCell>

        <mxCell id="n_m4" value="GET /api/notifications?limit=50&amp;unreadOnly=false (Bearer JWT)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="812" y="360" as="sourcePoint"/><mxPoint x="1032" y="360" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Self-call: GetRequiredUserId() from JWT — orthogonal U-shape right side of Controller -->
        <mxCell id="n_m5" value="GetRequiredUserId() from JWT Claims&#xa;(IDOR: never use URL param)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1032" y="395" as="sourcePoint"/>
            <mxPoint x="1032" y="435" as="targetPoint"/>
            <Array as="points"><mxPoint x="1095" y="395"/><mxPoint x="1095" y="435"/></Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="n_m6" value="SELECT * WHERE UserId={jwtUserId} ORDER BY CreatedAt DESC LIMIT 50"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1032" y="460" as="sourcePoint"/><mxPoint x="592" y="460" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m6r" value="Notification[] records"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="592" y="488" as="sourcePoint"/><mxPoint x="1032" y="488" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m7" value="200 OK: [{notificationId, title, message, isRead, createdAt}, ...]"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1032" y="516" as="sourcePoint"/><mxPoint x="812" y="516" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════
             SECTION C — Mark as Read (IDOR Prevention)
             Using UML «alt» Combined Fragment instead of rhombus
        ═══════════════════════════════════════════════════════ -->
        <mxCell id="n_sC" value="SECTION C — Mark as Read (IDOR Prevention Critical Path)"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="80" y="560" width="700" height="18" as="geometry"/></mxCell>

        <!-- C1: PATCH request -->
        <mxCell id="n_m8" value="PATCH /api/notifications/{id}/read (Bearer JWT)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="812" y="590" as="sourcePoint"/><mxPoint x="1032" y="590" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- C2: Self-call Extract jwtUserId — orthogonal U-shape -->
        <mxCell id="n_m9" value="Extract jwtUserId = GetRequiredUserId()"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1032" y="625" as="sourcePoint"/>
            <mxPoint x="1032" y="665" as="targetPoint"/>
            <Array as="points"><mxPoint x="1095" y="625"/><mxPoint x="1095" y="665"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- C3: SELECT notification -->
        <mxCell id="n_m10" value="SELECT Notification WHERE NotificationId={id}"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1032" y="690" as="sourcePoint"/><mxPoint x="592" y="690" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m10r" value="Notification {UserId=ownerUserId}"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="592" y="718" as="sourcePoint"/><mxPoint x="1032" y="718" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════
             UML «alt» COMBINED FRAGMENT
             Replaces rhombus + rounded box
             Frame: x=750 y=745 w=480 h=245
             Divider at y=745+100=845
        ═══════════════════════════ -->

        <!-- alt outer frame -->
        <mxCell id="n_alt_frame" value="alt"
          style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;
                 fillColor=none;strokeColor=#000000;strokeWidth=1.5;
                 spacingLeft=6;spacingTop=2;"
          vertex="1" parent="1">
          <mxGeometry x="750" y="745" width="480" height="245" as="geometry"/>
        </mxCell>

        <!-- alt top guard label -->
        <mxCell id="n_alt_g1" value="[jwtUserId ≠ ownerUserId]"
          style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="758" y="750" width="220" height="18" as="geometry"/>
        </mxCell>

        <!-- alt: 403 Forbidden branch -->
        <mxCell id="n_alt_403" value="403 Forbidden (IDOR Blocked)"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1032" y="790" as="sourcePoint"/><mxPoint x="812" y="790" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Divider line inside alt -->
        <mxCell id="n_alt_divider" value=""
          style="endArrow=none;dashed=1;dashPattern=6 3;html=1;strokeColor=#000000;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="750" y="845" as="sourcePoint"/><mxPoint x="1230" y="845" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- alt bottom guard label -->
        <mxCell id="n_alt_g2" value="[else — jwtUserId == ownerUserId]"
          style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="758" y="850" width="260" height="18" as="geometry"/>
        </mxCell>

        <!-- alt: UPDATE + 204 branch -->
        <mxCell id="n_m11" value="UPDATE SET IsRead=true WHERE NotificationId={id}"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1032" y="885" as="sourcePoint"/><mxPoint x="592" y="885" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m11r" value="204 No Content"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1032" y="960" as="sourcePoint"/><mxPoint x="812" y="960" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════
             SECTION D — Mark All as Read
        ═══════════════════════════════════════════════════════ -->
        <mxCell id="n_sD" value="SECTION D — Mark All as Read"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="80" y="1005" width="500" height="18" as="geometry"/></mxCell>

        <mxCell id="n_m12" value="POST /api/notifications/mark-all-read (Bearer JWT)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="812" y="1035" as="sourcePoint"/><mxPoint x="1032" y="1035" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m13" value="UPDATE SET IsRead=true WHERE UserId={jwtUserId} AND IsRead=false"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1032" y="1070" as="sourcePoint"/><mxPoint x="592" y="1070" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m13r" value="rowsAffected"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="592" y="1098" as="sourcePoint"/><mxPoint x="1032" y="1098" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m14" value="204 No Content"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1032" y="1126" as="sourcePoint"/><mxPoint x="812" y="1126" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════
             SECTION E — AuditMiddleware (fire-and-forget)
        ═══════════════════════════════════════════════════════ -->
        <mxCell id="n_sE" value="SECTION E — AuditMiddleware Logs Every PATCH/POST (fire-and-forget)"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="80" y="1168" width="900" height="18" as="geometry"/></mxCell>

        <mxCell id="n_m15" value="HMAC-SHA256(logId|ts|userId|action|ip)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;dashed=1;dashPattern=5 3;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1032" y="1198" as="sourcePoint"/><mxPoint x="1262" y="1198" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m16" value="INSERT AuditLog {Action='PATCH /notifications/{id}/read → 204'}"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;dashed=1;dashPattern=5 3;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1262" y="1235" as="sourcePoint"/><mxPoint x="592" y="1235" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ═══════════════════════════════════════════════════════════
       TAB 2 – FLOW DIAGRAM: DUAL-STREAM AUDIT LOG INTEGRITY
       (Giữ nguyên nội dung, chỉ dọn dẹp Flow Diagram với
        2 swimlane rõ ràng + diamond thay bằng rhombus chuẩn)
       ═══════════════════════════════════════════════════════════ -->
  <diagram name="Tab2 – Flow (Audit Log Integrity)" id="tab2-flow-audit">
    <mxGraphModel dx="1400" dy="960" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="1500" pageHeight="1450"
                  math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="al_title" value="Flow Diagram — Dual-Stream Audit Log Integrity (Write + Verify)"
          style="text;html=1;fontSize=15;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1200" height="28" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════
             STREAM 1 — WRITE IMMUTABLE AUDIT LOG
        ══════════════════════════════════════════════ -->
        <mxCell id="str1_hdr" value="STREAM 1 — Immutable Audit Log Write (AuditMiddleware + DB Triggers)"
          style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="40" y="55" width="700" height="22" as="geometry"/></mxCell>

        <mxCell id="sl_str1" value=""
          style="swimlane;startSize=0;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="660" height="650" as="geometry"/>
        </mxCell>

        <mxCell id="s1_start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="sl_str1"><mxGeometry x="306" y="20" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="s1_1" value="HTTP Request Arrives&#xa;(POST / PUT / PATCH / DELETE)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="220" y="70" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="s1_2" value="Auth / AuthZ → Controller handles"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="220" y="150" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="s1_3" value="Response sent to Client"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="220" y="230" width="200" height="44" as="geometry"/></mxCell>
        <mxCell id="s1_4" value="AuditMiddleware Fires&#xa;(fire-and-forget, async)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="220" y="305" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="s1_5" value="Collect: Method, Path, StatusCode,&#xa;UserId (JWT), IP (X-Forwarded-For)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="220" y="385" width="200" height="55" as="geometry"/></mxCell>
        <mxCell id="s1_6" value="Generate LogID = NewGuid()"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="220" y="470" width="200" height="44" as="geometry"/></mxCell>
        <mxCell id="s1_hmac" value="HMAC = HMAC-SHA256(serverKey,&#xa;'{logId}|{ts}|{actorId}|{action}|{ip}')&#xa;→ Base64Encode"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="40" y="495" width="155" height="70" as="geometry"/></mxCell>
        <mxCell id="s1_insert" value="INSERT AuditLog&#xa;{LogID, Timestamp, ActorID,&#xa;Action, IP, HMACSignature}"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="445" y="495" width="185" height="70" as="geometry"/></mxCell>
        <mxCell id="s1_trigger" value="DB Triggers — INSERT only:&#xa;trg_BlockUpdate → ROLLBACK on UPDATE&#xa;trg_BlockDelete → ROLLBACK on DELETE"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="125" y="595" width="400" height="35" as="geometry"/></mxCell>

        <mxCell id="s1e1" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_start" target="s1_1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e2" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_1" target="s1_2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e3" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_2" target="s1_3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e4" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_3" target="s1_4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e5" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_4" target="s1_5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e6" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_5" target="s1_6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e7" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_6" target="s1_hmac"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e8" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_6" target="s1_insert"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e9" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_hmac" target="s1_trigger"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e10" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_insert" target="s1_trigger"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ══════════════════════════════════════════════
             STREAM 2 — ADMIN VERIFY AUDIT LOG INTEGRITY
        ══════════════════════════════════════════════ -->
        <mxCell id="str2_hdr" value="STREAM 2 — Admin Verifies Audit Log Integrity (HMAC Re-hash + Compare)"
          style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="740" y="55" width="700" height="22" as="geometry"/></mxCell>

        <mxCell id="sl_str2" value=""
          style="swimlane;startSize=0;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;"
          vertex="1" parent="1">
          <mxGeometry x="740" y="85" width="680" height="1330" as="geometry"/>
        </mxCell>

        <mxCell id="s2_start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="sl_str2"><mxGeometry x="318" y="20" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="s2_1" value="Admin Logs In (JWT Auth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sl_str2"><mxGeometry x="228" y="68" width="200" height="44" as="geometry"/></mxCell>
        <mxCell id="s2_2" value="Navigate to Audit Log Viewer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sl_str2"><mxGeometry x="228" y="140" width="200" height="44" as="geometry"/></mxCell>
        <mxCell id="s2_3" value="GET /api/admin/audit-logs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sl_str2"><mxGeometry x="228" y="215" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="s2_4" value="SELECT AuditLogs&#xa;(AdminOnly policy enforced)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sl_str2"><mxGeometry x="228" y="295" width="200" height="50" as="geometry"/></mxCell>
        <mxCell id="s2_5" value="Return Logs to Admin UI&#xa;{logId, ts, actorId, action, ip, hmacSig}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontColor=#000000;" vertex="1" parent="sl_str2"><mxGeometry x="228" y="375" width="200" height="55" as="geometry"/></mxCell>

        <!-- Loop box -->
        <mxCell id="s2_loop_box" value="loop [for each AuditLog record]"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;strokeWidth=1.5;fontSize=10;fontStyle=2;verticalAlign=top;dashed=1;dashPattern=6 3;"
          vertex="1" parent="sl_str2"><mxGeometry x="30" y="455" width="620" height="520" as="geometry"/></mxCell>

        <mxCell id="s2_6" value="Re-compute HMAC-SHA256(serverKey,&#xa;'{logId}|{ts}|{actorId}|{action}|{ip}')"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="200" y="505" width="255" height="60" as="geometry"/></mxCell>
        <mxCell id="s2_7" value="Compare recomputedHMAC vs stored HMACSignature"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="200" y="600" width="255" height="50" as="geometry"/></mxCell>

        <!-- Decision: rhombus (correct for Flowchart/Activity, keeping in Flow tab) -->
        <mxCell id="s2_d1" value="HMAC&#xa;Match?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="240" y="680" width="140" height="80" as="geometry"/></mxCell>

        <mxCell id="s2_ok"   value="✓ INTEGRITY OK"  style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontColor=#000000;" vertex="1" parent="sl_str2"><mxGeometry x="60"  y="790" width="155" height="44" as="geometry"/></mxCell>
        <mxCell id="s2_fail" value="⚠ COMPROMISED&#xa;Tampered — sig mismatch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="sl_str2"><mxGeometry x="390" y="783" width="220" height="55" as="geometry"/></mxCell>
        <mxCell id="s2_next" value="Display Status per Record&#xa;in Admin Dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=12;fontColor=#000000;" vertex="1" parent="sl_str2"><mxGeometry x="200" y="875" width="255" height="50" as="geometry"/></mxCell>

        <mxCell id="s2_summary" value="Generate Integrity Report&#xa;Total: N | OK: X | Compromised: Y"
