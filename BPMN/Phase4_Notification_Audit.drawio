        <mxCell id="leg1" value="★ AuditLog records are INSERT-only (DB triggers block UPDATE/DELETE)"    style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="leg_box"><mxGeometry x="0" y="25" width="680" height="22" as="geometry"/></mxCell>
        <mxCell id="leg2" value="★ HMAC-SHA256 signature covers all mutable fields: logId|ts|actorId|action|ip" style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="leg_box"><mxGeometry x="0" y="47" width="680" height="22" as="geometry"/></mxCell>
        <mxCell id="leg3" value="★ Even DB admins cannot ALTER data without breaking the HMAC signature"  style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="leg_box"><mxGeometry x="0" y="69" width="680" height="22" as="geometry"/></mxCell>

