<!-- ============================================================
     PHASE 4 — NOTIFICATION & AUDIT LOG
     Tab 1 : Sequence Diagram – Notification + IDOR Prevention
     Tab 2 : Flow Diagram – Dual-Stream Audit Log Integrity
     Style  : Minimalist · Monochrome · Orthogonal edges
     ============================================================ -->

  <!-- ═══════════════════════════════════════════════════════════
       TAB 1 – SEQUENCE DIAGRAM: NOTIFICATION + IDOR CHECK
       ═══════════════════════════════════════════════════════════ -->
  <diagram name="Tab1 – Sequence (Notification + IDOR)" id="tab1-seq-notif">
    <mxGraphModel dx="1600" dy="960" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="1500" pageHeight="1200"
                  math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="n_title" value="Sequence Diagram — Notification System with IDOR Prevention"
          style="text;html=1;fontSize=15;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1200" height="28" as="geometry"/>
        </mxCell>

        <!-- Participants -->
        <mxCell id="n_p1" value="System Event&#xa;(Trigger)"       style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="50"   y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="n_p2" value="Notification&#xa;Service"          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="270"  y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="n_p3" value="DB&#xa;(Notification Table)"       style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="490"  y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="n_p4" value="User&#xa;(Any Role)"               style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="710"  y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="n_p5" value="Notifications&#xa;Controller"       style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="930"  y="55" width="140" height="44" as="geometry"/></mxCell>
        <mxCell id="n_p6" value="AuditLog&#xa;Middleware"           style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="1150" y="55" width="140" height="44" as="geometry"/></mxCell>

        <!-- Lifelines -->
        <mxCell id="n_ll1" value="" style="endArrow=none;dashed=1;dashPattern=5 4;strokeWidth=1;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120"  y="99" as="sourcePoint"/><mxPoint x="120"  y="1165" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="n_ll2" value="" style="endArrow=none;dashed=1;dashPattern=5 4;strokeWidth=1;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="340"  y="99" as="sourcePoint"/><mxPoint x="340"  y="1165" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="n_ll3" value="" style="endArrow=none;dashed=1;dashPattern=5 4;strokeWidth=1;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="560"  y="99" as="sourcePoint"/><mxPoint x="560"  y="1165" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="n_ll4" value="" style="endArrow=none;dashed=1;dashPattern=5 4;strokeWidth=1;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="780"  y="99" as="sourcePoint"/><mxPoint x="780"  y="1165" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="n_ll5" value="" style="endArrow=none;dashed=1;dashPattern=5 4;strokeWidth=1;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="99" as="sourcePoint"/><mxPoint x="1000" y="1165" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="n_ll6" value="" style="endArrow=none;dashed=1;dashPattern=5 4;strokeWidth=1;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1220" y="99" as="sourcePoint"/><mxPoint x="1220" y="1165" as="targetPoint"/></mxGeometry></mxCell>

        <!-- ── SECTION A: System Creates Notification ── -->
        <mxCell id="n_sA" value="SECTION A — System Pushes Notification (e.g. Exam Graded, Assignment Due)"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="50" y="115" width="800" height="18" as="geometry"/></mxCell>

        <mxCell id="n_m1" value="Event Fires (e.g. SubmissionGraded)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="120" y="143" as="sourcePoint"/><mxPoint x="340" y="143" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m2" value="Resolve Target UserId&#xa;(from context — NOT from client)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="340" y="170" as="sourcePoint"/><mxPoint x="340" y="200" as="targetPoint"/><Array as="points"><mxPoint x="410" y="170"/><mxPoint x="410" y="200"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="n_m3" value="INSERT Notification {UserId, Title, Message, IsRead=false, CreatedAt=UtcNow}"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="340" y="213" as="sourcePoint"/><mxPoint x="560" y="213" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m3r" value="notificationId"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="560" y="233" as="sourcePoint"/><mxPoint x="340" y="233" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ── SECTION B: User Fetches Notifications ── -->
        <mxCell id="n_sB" value="SECTION B — User Fetches Notification List"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="50" y="265" width="600" height="18" as="geometry"/></mxCell>

        <mxCell id="n_m4" value="GET /api/notifications?limit=50&amp;unreadOnly=false (Bearer JWT)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="780" y="293" as="sourcePoint"/><mxPoint x="1000" y="293" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m5" value="GetRequiredUserId() from JWT Claims&#xa;(IDOR: never use URL param)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="320" as="sourcePoint"/><mxPoint x="1000" y="350" as="targetPoint"/><Array as="points"><mxPoint x="1070" y="320"/><mxPoint x="1070" y="350"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="n_m6" value="SELECT * WHERE UserId={jwtUserId} ORDER BY CreatedAt DESC LIMIT 50"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="365" as="sourcePoint"/><mxPoint x="560" y="365" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m6r" value="Notification[] records"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="560" y="383" as="sourcePoint"/><mxPoint x="1000" y="383" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m7" value="200 OK: [{notificationId, title, message, isRead, createdAt}, ...]"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="408" as="sourcePoint"/><mxPoint x="780" y="408" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ── SECTION C: Mark Single as Read (IDOR Check) ── -->
        <mxCell id="n_sC" value="SECTION C — Mark as Read (IDOR Prevention Critical Path)"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="50" y="440" width="700" height="18" as="geometry"/></mxCell>

        <mxCell id="n_idor_box" value="IDOR Protection Block"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;fontStyle=1;verticalAlign=top;dashed=1;dashPattern=6 3;"
          vertex="1" parent="1"><mxGeometry x="700" y="468" width="450" height="260" as="geometry"/></mxCell>

        <mxCell id="n_m8" value="PATCH /api/notifications/{id}/read (Bearer JWT)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="780" y="495" as="sourcePoint"/><mxPoint x="1000" y="495" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m9" value="Extract jwtUserId = GetRequiredUserId()"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="523" as="sourcePoint"/><mxPoint x="1000" y="553" as="targetPoint"/><Array as="points"><mxPoint x="1070" y="523"/><mxPoint x="1070" y="553"/></Array></mxGeometry>
        </mxCell>
        <mxCell id="n_m10" value="SELECT Notification WHERE NotificationId={id}"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="568" as="sourcePoint"/><mxPoint x="560" y="568" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m10r" value="Notification {UserId=ownerUserId}"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="560" y="588" as="sourcePoint"/><mxPoint x="1000" y="588" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- IDOR Decision -->
        <mxCell id="n_d_idor" value="jwtUserId ==&#xa;ownerUserId?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=11;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="910" y="605" width="155" height="80" as="geometry"/></mxCell>

        <mxCell id="n_403" value="Return 403 Forbidden&#xa;(IDOR Blocked)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=11;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="1100" y="628" width="155" height="44" as="geometry"/></mxCell>

        <mxCell id="n_m11" value="UPDATE SET IsRead=true WHERE NotificationId={id}"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="700" as="sourcePoint"/><mxPoint x="560" y="700" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m11r" value="204 No Content"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="560" y="720" as="sourcePoint"/><mxPoint x="780" y="720" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- IDOR edges -->
        <mxCell id="n_e_idor1" value="No (different user)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="n_d_idor" target="n_403"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="n_e_idor2" value="Yes (owner)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="988" y="685" as="sourcePoint"/><mxPoint x="1000" y="685" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ── SECTION D: Mark All as Read ── -->
        <mxCell id="n_sD" value="SECTION D — Mark All as Read"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="50" y="755" width="500" height="18" as="geometry"/></mxCell>

        <mxCell id="n_m12" value="POST /api/notifications/mark-all-read (Bearer JWT)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="780" y="783" as="sourcePoint"/><mxPoint x="1000" y="783" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m13" value="UPDATE SET IsRead=true WHERE UserId={jwtUserId} AND IsRead=false"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="810" as="sourcePoint"/><mxPoint x="560" y="810" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m13r" value="rowsAffected"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="560" y="828" as="sourcePoint"/><mxPoint x="1000" y="828" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m14" value="204 No Content"
          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="855" as="sourcePoint"/><mxPoint x="780" y="855" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ── SECTION E: AuditMiddleware logs PATCH/POST ── -->
        <mxCell id="n_sE" value="SECTION E — AuditMiddleware Logs Every PATCH/POST (fire-and-forget)"
          style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="50" y="885" width="900" height="18" as="geometry"/></mxCell>

        <mxCell id="n_m15" value="HMAC-SHA256(logId|ts|userId|action|ip)"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;dashed=1;dashPattern=5 3;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="913" as="sourcePoint"/><mxPoint x="1220" y="913" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="n_m16" value="INSERT AuditLog {Action='PATCH /notifications/{id}/read -> 204'}"
          style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;dashed=1;dashPattern=5 3;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1220" y="940" as="sourcePoint"/><mxPoint x="560" y="940" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ═══════════════════════════════════════════════════════════
       TAB 2 – FLOW DIAGRAM: DUAL-STREAM AUDIT LOG INTEGRITY
       ═══════════════════════════════════════════════════════════ -->
  <diagram name="Tab2 – Flow (Audit Log Integrity)" id="tab2-flow-audit">
    <mxGraphModel dx="1400" dy="960" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="1500" pageHeight="1400"
                  math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="al_title" value="Flow Diagram — Dual-Stream Audit Log Integrity (Write + Verify)"
          style="text;html=1;fontSize=15;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1200" height="28" as="geometry"/>
        </mxCell>

        <!-- ══════════════════════════════════════════════
             STREAM 1 — WRITE IMMUTABLE AUDIT LOG
             ══════════════════════════════════════════════ -->
        <mxCell id="str1_hdr" value="STREAM 1 — Immutable Audit Log Write (AuditMiddleware + DB Triggers)"
          style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="40" y="55" width="800" height="22" as="geometry"/></mxCell>

        <!-- Swimlane: Stream 1 -->
        <mxCell id="sl_str1" value=""
          style="swimlane;startSize=0;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=13;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="680" height="590" as="geometry"/>
        </mxCell>

        <!-- S1 Start -->
        <mxCell id="s1_start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="sl_str1"><mxGeometry x="310" y="20" width="28" height="28" as="geometry"/></mxCell>

        <mxCell id="s1_1" value="HTTP Request Arrives&#xa;(POST / PUT / PATCH / DELETE)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="225" y="68" width="200" height="50" as="geometry"/></mxCell>

        <mxCell id="s1_2" value="UseAuthentication() → UseAuthorization()&#xa;→ Controller handles request"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="225" y="140" width="200" height="55" as="geometry"/></mxCell>

        <mxCell id="s1_3" value="Response sent to Client"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="225" y="218" width="200" height="44" as="geometry"/></mxCell>

        <mxCell id="s1_4" value="AuditMiddleware Fires&#xa;(fire-and-forget, async)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=12;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="225" y="285" width="200" height="50" as="geometry"/></mxCell>

        <mxCell id="s1_5" value="Collect: Method, Path, StatusCode,&#xa;UserId (JWT), IP (X-Forwarded-For)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=11;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="225" y="358" width="200" height="55" as="geometry"/></mxCell>

        <mxCell id="s1_6" value="Generate LogID = NewGuid()"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="225" y="435" width="200" height="44" as="geometry"/></mxCell>

        <mxCell id="s1_hmac" value="HMAC = HMAC-SHA256(serverKey,&#xa;'{logId}|{ts}|{actorId}|{action}|{ip}')&#xa;→ Base64Encode"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=11;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="40" y="460" width="165" height="70" as="geometry"/></mxCell>

        <mxCell id="s1_insert" value="INSERT AuditLog&#xa;{LogID, Timestamp, ActorID,&#xa;Action, IP, HMACSignature}"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=11;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="450" y="460" width="190" height="70" as="geometry"/></mxCell>

        <mxCell id="s1_trigger" value="DB Triggers enforce immutability:&#xa;trg_AuditLogs_BlockUpdate → ROLLBACK on UPDATE&#xa;trg_AuditLogs_BlockDelete → ROLLBACK on DELETE"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=11;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="sl_str1"><mxGeometry x="130" y="550" width="400" height="28" as="geometry"/></mxCell>

        <!-- S1 Edges -->
        <mxCell id="s1e1" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_start" target="s1_1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e2" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_1" target="s1_2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e3" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_2" target="s1_3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e4" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_3" target="s1_4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e5" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_4" target="s1_5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e6" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_5" target="s1_6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e7" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_6" target="s1_hmac"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e8" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_6" target="s1_insert"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e9" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_hmac" target="s1_trigger"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s1e10" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str1" source="s1_insert" target="s1_trigger"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ══════════════════════════════════════════════
             STREAM 2 — ADMIN VERIFY AUDIT LOG INTEGRITY
             ══════════════════════════════════════════════ -->
        <mxCell id="str2_hdr" value="STREAM 2 — Admin Verifies Audit Log Integrity (HMAC Re-hash + Compare)"
          style="text;html=1;fontSize=13;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="760" y="55" width="700" height="22" as="geometry"/></mxCell>

        <mxCell id="sl_str2" value=""
          style="swimlane;startSize=0;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=13;fontColor=#000000;"
          vertex="1" parent="1">
          <mxGeometry x="760" y="85" width="660" height="1270" as="geometry"/>
        </mxCell>

        <mxCell id="s2_start" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="sl_str2"><mxGeometry x="298" y="20" width="28" height="28" as="geometry"/></mxCell>

        <mxCell id="s2_1" value="Admin Logs In (JWT Auth)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="215" y="68" width="195" height="44" as="geometry"/></mxCell>

        <mxCell id="s2_2" value="Navigate to Audit Log Viewer"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="215" y="135" width="195" height="44" as="geometry"/></mxCell>

        <mxCell id="s2_3" value="Request Audit Logs&#xa;(GET /api/admin/audit-logs)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="215" y="202" width="195" height="50" as="geometry"/></mxCell>

        <mxCell id="s2_4" value="SELECT AuditLogs&#xa;(AdminOnly policy enforced)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="215" y="278" width="195" height="50" as="geometry"/></mxCell>

        <mxCell id="s2_5" value="Return Logs to Admin UI&#xa;{logId, ts, actorId, action, ip, hmacSig}"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=11;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="215" y="352" width="195" height="55" as="geometry"/></mxCell>

        <!-- Iteration loop per record -->
        <mxCell id="s2_loop_box" value="loop [for each AuditLog record]"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;fontSize=10;fontStyle=2;verticalAlign=top;dashed=1;dashPattern=6 3;"
          vertex="1" parent="sl_str2"><mxGeometry x="30" y="430" width="590" height="480" as="geometry"/></mxCell>

        <mxCell id="s2_6" value="Re-compute HMAC-SHA256(serverKey,&#xa;'{logId}|{ts}|{actorId}|{action}|{ip}')"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=11;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="185" y="475" width="240" height="60" as="geometry"/></mxCell>

        <mxCell id="s2_7" value="Compare recomputedHMAC&#xa;vs stored HMACSignature"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="185" y="560" width="240" height="50" as="geometry"/></mxCell>

        <!-- Decision -->
        <mxCell id="s2_d1" value="HMAC&#xa;Match?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="225" y="635" width="130" height="80" as="geometry"/></mxCell>

        <!-- Branch: OK -->
        <mxCell id="s2_ok" value="✓ Mark Record:&#xa;INTEGRITY OK"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=11;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="60" y="725" width="150" height="50" as="geometry"/></mxCell>

        <!-- Branch: Compromised -->
        <mxCell id="s2_fail" value="⚠ ALERT: Record COMPROMISED&#xa;Stored signature ≠ Re-computed&#xa;→ Log data was tampered"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=11;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="370" y="718" width="215" height="65" as="geometry"/></mxCell>

        <!-- Next record -->
        <mxCell id="s2_next" value="Display Status per Record&#xa;in Admin Dashboard"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="185" y="820" width="240" height="50" as="geometry"/></mxCell>

        <!-- Summary -->
        <mxCell id="s2_summary" value="Generate Integrity Report&#xa;Total: N records | OK: X | Compromised: Y"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="185" y="945" width="240" height="55" as="geometry"/></mxCell>

        <!-- Decision: Any compromised? -->
        <mxCell id="s2_d2" value="Any&#xa;Compromised?"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=12;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="220" y="1025" width="150" height="80" as="geometry"/></mxCell>

        <mxCell id="s2_alert" value="Raise Security Alert&#xa;Escalate to SOC / System Owner"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#000000;fontSize=11;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="sl_str2"><mxGeometry x="420" y="1048" width="200" height="50" as="geometry"/></mxCell>

        <mxCell id="s2_end" value="" style="ellipse;fillColor=#000000;strokeColor=#000000;shape=doubleEllipse;" vertex="1" parent="sl_str2"><mxGeometry x="298" y="1140" width="28" height="28" as="geometry"/></mxCell>

        <!-- S2 Edges -->
        <mxCell id="s2e1"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_start"   target="s2_1"      ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e2"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_1"        target="s2_2"      ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e3"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_2"        target="s2_3"      ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e4"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_3"        target="s2_4"      ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e5"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_4"        target="s2_5"      ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e6"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_5"        target="s2_6"      ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e7"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_6"        target="s2_7"      ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e8"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_7"        target="s2_d1"     ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e9"  value="Yes" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sl_str2" source="s2_d1" target="s2_ok"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e10" value="No"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sl_str2" source="s2_d1" target="s2_fail"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e11" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_ok"        target="s2_next"   ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e12" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_fail"      target="s2_next"   ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e13" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_next"      target="s2_summary"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e14" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_summary"   target="s2_d2"     ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e15" value="Yes" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sl_str2" source="s2_d2"    target="s2_alert"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e16" value="No"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sl_str2" source="s2_d2"    target="s2_end"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e17" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_alert"     target="s2_end"    ><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Legend -->
        <mxCell id="leg_box" value="Legend"
          style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#000000;fontSize=11;fontStyle=1;fontColor=#000000;"
          vertex="1" parent="1"><mxGeometry x="40" y="700" width="680" height="130" as="geometry"/></mxCell>
        <mxCell id="leg1" value="★ AuditLog records are INSERT-only (no UPDATE/DELETE possible — DB triggers block it)"  style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="leg_box"><mxGeometry x="0" y="25" width="680" height="22" as="geometry"/></mxCell>
        <mxCell id="leg2" value="★ HMAC-SHA256 signature covers all mutable fields: logId, timestamp, actorId, action, ip" style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="leg_box"><mxGeometry x="0" y="47" width="680" height="22" as="geometry"/></mxCell>
        <mxCell id="leg3" value="★ Even DB admins cannot ALTER data without breaking the HMAC signature"                   style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="leg_box"><mxGeometry x="0" y="69" width="680" height="22" as="geometry"/></mxCell>
        <mxCell id="leg4" value="★ Admin Verify tool re-derives HMAC using the same server key and detects any mismatch"   style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="leg_box"><mxGeometry x="0" y="91" width="680" height="22" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>

