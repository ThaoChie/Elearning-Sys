        <mxCell id="s2e4"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_3"        target="s2_4"      ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e5"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_4"        target="s2_5"      ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e6"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_5"        target="s2_6"      ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e7"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_6"        target="s2_7"      ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e8"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_7"        target="s2_d1"     ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e9"  value="Yes" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sl_str2" source="s2_d1" target="s2_ok"  ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e10" value="No"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sl_str2" source="s2_d1" target="s2_fail"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e11" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_ok"        target="s2_next"   ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e12" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_fail"      target="s2_next"   ><mxGeometry relative="1" as="geometry"/></mxCell>
