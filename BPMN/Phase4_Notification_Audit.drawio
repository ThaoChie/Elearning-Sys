        <mxCell id="s2e1"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_start"   target="s2_1"      ><mxGeometry relative="1" as="geometry"/></mxCell>
