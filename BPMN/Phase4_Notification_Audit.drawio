        <mxCell id="s2e15" value="Yes" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sl_str2" source="s2_d2"   target="s2_alert"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e16" value="No"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontSize=10;" edge="1" parent="sl_str2" source="s2_d2"   target="s2_end"  ><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2e17" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="sl_str2" source="s2_alert"     target="s2_end"    ><mxGeometry relative="1" as="geometry"/></mxCell>

