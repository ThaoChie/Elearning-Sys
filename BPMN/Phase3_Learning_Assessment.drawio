                        <mxPoint x="325" y="778" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ac_m17" value="onMaxViolations() → Navigate to Result Page" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
