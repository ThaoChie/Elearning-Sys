                <mxCell id="ac_m11" value="violationCount++ (local ref)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
