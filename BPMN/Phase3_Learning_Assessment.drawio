            <Array as="points"><mxPoint x="395" y="690"/><mxPoint x="395" y="730"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="ac_m12"  value="POST /api/exam/{id}/violation {violationType:'TabSwitch'}"   style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="335" y="758" as="sourcePoint"/><mxPoint x="755" y="758" as="targetPoint"/></mxGeometry></mxCell>
        <!-- self-call: RecordViolation on DB -->
        <mxCell id="ac_m13" value="RecordViolation() → ViolationCount++" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="965" y="793" as="sourcePoint"/>
            <mxPoint x="965" y="833" as="targetPoint"/>
            <Array as="points"><mxPoint x="1025" y="793"/><mxPoint x="1025" y="833"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="ac_m13r" value="200 {violationCount, isForceSubmitted: false}" style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="755" y="860" as="sourcePoint"/><mxPoint x="335" y="860" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ac_warn" value="Show Warning Modal (violation 1 or 2)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="335" y="895" as="sourcePoint"/><mxPoint x="125" y="895" as="targetPoint"/></mxGeometry></mxCell>
        <!-- PHASE 5: opt fragment -->
        <mxCell id="ac_s5" value="PHASE 5 — Violation ≥ 3 → Force Submit" style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="60" y="930" width="500" height="18" as="geometry"/></mxCell>
        <mxCell id="ac_opt" value="opt" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#000000;strokeWidth=1.5;spacingLeft=6;spacingTop=2;" vertex="1" parent="1"><mxGeometry x="60" y="950" width="1250" height="155" as="geometry"/></mxCell>
        <mxCell id="ac_optg" value="[violationCount ≥ 3]" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="70" y="955" width="180" height="18" as="geometry"/></mxCell>
        <mxCell id="ac_m14" value="POST /api/exam/{id}/violation (3rd time)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="335" y="985" as="sourcePoint"/><mxPoint x="755" y="985" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ac_m15" value="ViolationCount=3 → Status=ForceSubmitted" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="755" y="1015" as="sourcePoint"/><mxPoint x="965" y="1015" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ac_m16" value="400 exam_force_submitted → onMaxViolations() → Navigate to Result" style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="755" y="1068" as="sourcePoint"/><mxPoint x="125" y="1068" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ac_m18" value="AuditLog: POST /violation → ForceSubmit" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;dashed=1;dashPattern=5 3;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="755" y="1088" as="sourcePoint"/><mxPoint x="1175" y="1088" as="targetPoint"/></mxGeometry></mxCell>
        <!-- PHASE 6: Normal Submit -->
        <mxCell id="ac_s6" value="PHASE 6 — Student Submits Normally" style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="60" y="1130" width="500" height="18" as="geometry"/></mxCell>
        <mxCell id="ac_m19" value="Click 'Submit Exam'" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="125" y="1160" as="sourcePoint"/><mxPoint x="545" y="1160" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ac_m20" value="POST /api/exam/{id}/submit" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="545" y="1193" as="sourcePoint"/><mxPoint x="755" y="1193" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ac_m21" value="Status = Submitted" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="755" y="1223" as="sourcePoint"/><mxPoint x="965" y="1223" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ac_m21r" value="200 OK – Exam Completed" style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="755" y="1253" as="sourcePoint"/><mxPoint x="125" y="1253" as="targetPoint"/></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <!-- ═══════════════════════════════════════════════════════════
