                </mxCell>
                <mxCell id="ap_ll7" value="" style="endArrow=none;dashed=1;dashPattern=5 4;strokeWidth=1;strokeColor=#888888;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1300" y="99" as="sourcePoint"/>
                        <mxPoint x="1300" y="1070" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <!-- Step labels -->
                <mxCell id="ap_lbl0" value="POST /api/assignments/{id}/submit (multipart/form-data, Bearer JWT)" style="text;html=1;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#000000;" vertex="1" parent="1">
                    <mxGeometry x="50" y="115" width="700" height="20" as="geometry"/>
                </mxCell>
                <!-- Step 1: JWT Extract -->
                <mxCell id="ap_step1_lbl" value="STEP 1 — Extract StudentId from JWT Claims (401 if missing)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
                    <mxGeometry x="50" y="145" width="550" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="ap_m1" value="POST /submit (Bearer JWT, file)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="110" y="170" as="sourcePoint"/>
                        <mxPoint x="300" y="170" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ap_m1a" value="GetRequiredUserId() from JWT Claims" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="195" as="sourcePoint"/><mxPoint x="300" y="225" as="targetPoint"/><Array as="points"><mxPoint x="370" y="195"/><mxPoint x="370" y="225"/></Array></mxGeometry>
                </mxCell>
                <!-- Step 2: Assignment Exists -->
                <mxCell id="ap_step2_lbl" value="STEP 2 — Assignment Exists in DB (404 if not found)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
                    <mxGeometry x="50" y="235" width="550" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="ap_m2" value="SELECT Assignment WHERE Id={id}" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="300" y="258" as="sourcePoint"/>
                        <mxPoint x="500" y="258" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ap_m2r" value="Assignment record / null" style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="500" y="278" as="sourcePoint"/>
                        <mxPoint x="300" y="278" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <!-- Step 3: Duplicate Check -->
                <mxCell id="ap_step3_lbl" value="STEP 3 — Duplicate Submission Check (409 already_submitted)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
                    <mxGeometry x="50" y="305" width="600" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="ap_m3" value="SELECT COUNT WHERE assignmentId+studentId" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="300" y="328" as="sourcePoint"/>
                        <mxPoint x="500" y="328" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ap_m3r" value="0 (no duplicate)" style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="500" y="348" as="sourcePoint"/>
                        <mxPoint x="300" y="348" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <!-- Step 4: File Size -->
                <mxCell id="ap_step4_lbl" value="STEP 4 — File Size Check: 0 &lt; size ≤ 50 MB  (400 file_too_large)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
                    <mxGeometry x="50" y="372" width="650" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="ap_m4" value="file.Length check" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="395" as="sourcePoint"/><mxPoint x="300" y="425" as="targetPoint"/><Array as="points"><mxPoint x="370" y="395"/><mxPoint x="370" y="425"/></Array></mxGeometry>
                </mxCell>
                <!-- Step 5: MIME Validation -->
                <mxCell id="ap_step5_lbl" value="STEP 5 — Read Magic Bytes (8 bytes) + Match MIME Allow-list  (422 invalid_mime_type)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
                    <mxGeometry x="50" y="432" width="750" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="ap_m5" value="ReadAsync first 8 bytes (magic bytes)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="300" y="455" as="sourcePoint"/>
                        <mxPoint x="700" y="455" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ap_m5r" value="Valid MIME / 422 invalid_mime_type" style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="700" y="473" as="sourcePoint"/>
                        <mxPoint x="300" y="473" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <!-- Step 6: ClamAV -->
                <mxCell id="ap_step6_lbl" value="STEP 6 — ClamAV TCP INSTREAM Scan (chunks 4096B)  (422 virus_detected)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
                    <mxGeometry x="50" y="498" width="750" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="ap_m6" value="INSTREAM {fileChunks 4096B each}" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="300" y="523" as="sourcePoint"/>
                        <mxPoint x="900" y="523" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ap_m6r" value="&#39;stream: OK&#39; / &#39;stream: FOUND virusname&#39;" style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="900" y="543" as="sourcePoint"/>
                        <mxPoint x="300" y="543" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <!-- Step 7: AES-256 Encrypt + MinIO Upload -->
                <mxCell id="ap_step7_lbl" value="STEP 7 — AES-256-CBC Encrypt (random 16B IV prepended) + Upload MinIO with UUID StorageKey" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1">
                    <mxGeometry x="50" y="568" width="1050" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="ap_m7a" value="Encrypt(fileBytes, AES-256-CBC, random IV)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="300" y="593" as="sourcePoint"/>
                        <mxPoint x="1100" y="593" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ap_m7ar" value="[IV + ciphertext] bytes" style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1100" y="613" as="sourcePoint"/>
                        <mxPoint x="300" y="613" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ap_m7b" value="PutObject(key=UUID.enc, body=encryptedBytes)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="300" y="640" as="sourcePoint"/>
                        <mxPoint x="1300" y="640" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ap_m7br" value="ACK" style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1300" y="660" as="sourcePoint"/>
                        <mxPoint x="300" y="660" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <!-- Persist submission -->
                <mxCell id="ap_m8" value="INSERT AssignmentSubmission {StorageKey=UUID.enc, MimeType, FileSizeBytes}" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="300" y="688" as="sourcePoint"/>
                        <mxPoint x="500" y="688" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ap_m9" value="201 Created {submissionId}" style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="300" y="715" as="sourcePoint"/>
                        <mxPoint x="110" y="715" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <!-- Error summary box -->
                <mxCell id="ap_err_box" value="Error Responses Summary" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#000000;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
                    <mxGeometry x="50" y="750" width="550" height="270" as="geometry"/>
                </mxCell>
                <mxCell id="ap_er1" value="Step 1 fail → 401 Unauthorized (missing JWT)" style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="ap_err_box">
                    <mxGeometry x="0" y="25" width="550" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="ap_er2" value="Step 2 fail → 404 assignment_not_found" style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="ap_err_box">
                    <mxGeometry x="0" y="47" width="550" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="ap_er3" value="Step 3 fail → 409 already_submitted" style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="ap_err_box">
