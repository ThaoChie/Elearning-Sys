        <mxCell id="ap_ll4" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="680"  y="99" as="sourcePoint"/><mxPoint x="680"  y="1170" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ap_ll5" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="870"  y="99" as="sourcePoint"/><mxPoint x="870"  y="1170" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ap_ll6" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1060" y="99" as="sourcePoint"/><mxPoint x="1060" y="1170" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ap_ll7" value="" style="endArrow=none;dashed=1;dashPattern=6 4;strokeWidth=1.5;strokeColor=#888888;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1250" y="99" as="sourcePoint"/><mxPoint x="1250" y="1170" as="targetPoint"/></mxGeometry></mxCell>
        <!-- STEP 1 -->
        <mxCell id="ap_s1" value="STEP 1 — Extract StudentId from JWT (401 if missing)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="50" y="115" width="580" height="18" as="geometry"/></mxCell>
        <mxCell id="ap_m1" value="POST /api/assignments/{id}/submit (Bearer JWT, file)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="110" y="143" as="sourcePoint"/><mxPoint x="300" y="143" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ap_m1a" value="GetRequiredUserId() from JWT Claims" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="180" as="sourcePoint"/><mxPoint x="300" y="220" as="targetPoint"/><Array as="points"><mxPoint x="362" y="180"/><mxPoint x="362" y="220"/></Array></mxGeometry>
        </mxCell>
        <!-- STEP 2 -->
        <mxCell id="ap_s2" value="STEP 2 — Assignment Exists in DB (404)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="50" y="248" width="520" height="18" as="geometry"/></mxCell>
        <mxCell id="ap_m2"  value="SELECT Assignment WHERE Id={id}"    style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="275" as="sourcePoint"/><mxPoint x="490" y="275" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ap_m2r" value="Assignment record"                   style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="490" y="305" as="sourcePoint"/><mxPoint x="300" y="305" as="targetPoint"/></mxGeometry></mxCell>
        <!-- STEP 3 -->
        <mxCell id="ap_s3" value="STEP 3 — Duplicate Check (409)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="50" y="333" width="520" height="18" as="geometry"/></mxCell>
        <mxCell id="ap_m3"  value="SELECT COUNT WHERE assignmentId+studentId" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="360" as="sourcePoint"/><mxPoint x="490" y="360" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ap_m3r" value="0 (no duplicate)"                          style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="490" y="390" as="sourcePoint"/><mxPoint x="300" y="390" as="targetPoint"/></mxGeometry></mxCell>
        <!-- STEP 4 -->
        <mxCell id="ap_s4" value="STEP 4 — File Size Check: 0 &lt; size ≤ 50 MB  (400)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="50" y="418" width="680" height="18" as="geometry"/></mxCell>
        <mxCell id="ap_m4" value="file.Length check (0 &lt; size ≤ 52428800 bytes)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;labelBackgroundColor=#ffffff;align=left;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="300" y="445" as="sourcePoint"/><mxPoint x="300" y="485" as="targetPoint"/><Array as="points"><mxPoint x="362" y="445"/><mxPoint x="362" y="485"/></Array></mxGeometry>
        </mxCell>
        <!-- STEP 5 -->
        <mxCell id="ap_s5" value="STEP 5 — Magic Bytes MIME Validate  (422 invalid_mime_type)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="50" y="515" width="780" height="18" as="geometry"/></mxCell>
        <mxCell id="ap_m5"  value="ReadAsync first 8 bytes (magic bytes)"  style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="543" as="sourcePoint"/><mxPoint x="680" y="543" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ap_m5r" value="Valid MIME / 422 invalid_mime_type"     style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="680" y="573" as="sourcePoint"/><mxPoint x="300" y="573" as="targetPoint"/></mxGeometry></mxCell>
        <!-- STEP 6 -->
        <mxCell id="ap_s6" value="STEP 6 — ClamAV TCP INSTREAM Scan 4096B chunks  (422 virus_detected)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="50" y="603" width="850" height="18" as="geometry"/></mxCell>
        <mxCell id="ap_m6"  value="INSTREAM {fileChunks 4096B each}"              style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="630" as="sourcePoint"/><mxPoint x="870" y="630" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ap_m6r" value="'stream: OK' / 'stream: FOUND virusname'"      style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="870" y="660" as="sourcePoint"/><mxPoint x="300" y="660" as="targetPoint"/></mxGeometry></mxCell>
        <!-- STEP 7 -->
        <mxCell id="ap_s7" value="STEP 7 — AES-256-CBC Encrypt + MinIO Upload (UUID StorageKey)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="50" y="690" width="950" height="18" as="geometry"/></mxCell>
        <mxCell id="ap_m7a"  value="Encrypt(fileBytes, AES-256-CBC, random IV)"         style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="718" as="sourcePoint"/><mxPoint x="1060" y="718" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ap_m7ar" value="[IV + ciphertext] bytes"                             style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1060" y="750" as="sourcePoint"/><mxPoint x="300" y="750" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ap_m7b"  value="PutObject(key=UUID.enc, body=encryptedBytes)"       style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="785" as="sourcePoint"/><mxPoint x="1250" y="785" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ap_m7br" value="ACK"                                                 style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1250" y="815" as="sourcePoint"/><mxPoint x="300" y="815" as="targetPoint"/></mxGeometry></mxCell>
        <!-- Persist + 201 -->
        <mxCell id="ap_m8"  value="INSERT AssignmentSubmission {StorageKey=UUID.enc, MimeType, FileSizeBytes}" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="853" as="sourcePoint"/><mxPoint x="490" y="853" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ap_m9"  value="201 Created {submissionId}"                                                 style="endArrow=open;endFill=0;dashed=1;html=1;strokeColor=#000000;strokeWidth=1.5;fontSize=10;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="890" as="sourcePoint"/><mxPoint x="110" y="890" as="targetPoint"/></mxGeometry></mxCell>
        <!-- Error box -->
        <mxCell id="ap_err_box" value="Error Responses Summary" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontSize=11;fontStyle=1;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="50" y="928" width="570" height="220" as="geometry"/></mxCell>
        <mxCell id="ap_er1" value="Step 1 → 401 Unauthorized (missing JWT)" style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="ap_err_box"><mxGeometry x="0" y="25"  width="570" height="22" as="geometry"/></mxCell>
        <mxCell id="ap_er2" value="Step 2 → 404 assignment_not_found"        style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="ap_err_box"><mxGeometry x="0" y="47"  width="570" height="22" as="geometry"/></mxCell>
        <mxCell id="ap_er3" value="Step 3 → 409 already_submitted"           style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="ap_err_box"><mxGeometry x="0" y="69"  width="570" height="22" as="geometry"/></mxCell>
        <mxCell id="ap_er4" value="Step 4 → 400 file_too_large"              style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="ap_err_box"><mxGeometry x="0" y="91"  width="570" height="22" as="geometry"/></mxCell>
        <mxCell id="ap_er5" value="Step 5 → 422 invalid_mime_type"           style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="ap_err_box"><mxGeometry x="0" y="113" width="570" height="22" as="geometry"/></mxCell>
        <mxCell id="ap_er6" value="Step 6 → 422 virus_detected"              style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontColor=#000000;spacingLeft=8;" vertex="1" parent="ap_err_box"><mxGeometry x="0" y="135" width="570" height="22" as="geometry"/></mxCell>
        <mxCell id="ap_er7" value="Step 7 success → 201 Created"             style="text;html=1;align=left;fillColor=none;strokeColor=none;fontSize=11;fontStyle=1;fontColor=#000000;spacingLeft=8;" vertex="1" parent="ap_err_box"><mxGeometry x="0" y="157" width="570" height="22" as="geometry"/></mxCell>
      </root>
