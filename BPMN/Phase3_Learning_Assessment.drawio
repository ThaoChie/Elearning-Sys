                        <mxPoint x="125" y="673" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ac_s5" value="PHASE 5 — Violation ≥ 3 → Force Submit" style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;" parent="1" vertex="1">
                    <mxGeometry x="60" y="700" width="500" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="ac_m14" value="POST /api/exam/{id}/violation (3rd time)" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
