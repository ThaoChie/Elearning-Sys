                    </mxGeometry>
                </mxCell>
                <mxCell id="ac_m12" value="POST /api/exam/{id}/violation {violationType:&#39;TabSwitch&#39;}" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;fontSize=10;edgeStyle=orthogonalEdgeStyle;" parent="1" edge="1">
                    <mxGeometry x="0.0238" y="18" relative="1" as="geometry">
