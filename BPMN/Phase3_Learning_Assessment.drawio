        </mxGraphModel>
    </diagram>
    <diagram name="Tab3 – Sequence (Assignment Pipeline)" id="tab3-seq-assignment">
        <mxGraphModel dx="1600" dy="960" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="ap_title" value="Sequence Diagram — Assignment Submission Security Pipeline (7 Steps)" style="text;html=1;fontSize=15;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#000000;" vertex="1" parent="1">
                    <mxGeometry x="100" y="10" width="1250" height="28" as="geometry"/>
                </mxCell>
                <!-- Participants -->
                <mxCell id="ap_p1" value="Student" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
                    <mxGeometry x="50" y="55" width="120" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="ap_p2" value="Assignment&#xa;Controller" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
                    <mxGeometry x="240" y="55" width="120" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="ap_p3" value="DB&#xa;(SQL Server)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
                    <mxGeometry x="440" y="55" width="120" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="ap_p4" value="MIME&#xa;Validator" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
                    <mxGeometry x="640" y="55" width="120" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="ap_p5" value="ClamAV&#xa;(TCP Daemon)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
                    <mxGeometry x="840" y="55" width="120" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="ap_p6" value="AES-256&#xa;Service" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
                    <mxGeometry x="1040" y="55" width="120" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="ap_p7" value="MinIO&#xa;(Storage)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1">
                    <mxGeometry x="1240" y="55" width="120" height="44" as="geometry"/>
                </mxCell>
                <!-- Lifelines -->
                <mxCell id="ap_ll1" value="" style="endArrow=none;dashed=1;dashPattern=5 4;strokeWidth=1;strokeColor=#888888;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="110" y="99" as="sourcePoint"/>
                        <mxPoint x="110" y="1070" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ap_ll2" value="" style="endArrow=none;dashed=1;dashPattern=5 4;strokeWidth=1;strokeColor=#888888;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="300" y="99" as="sourcePoint"/>
                        <mxPoint x="300" y="1070" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="ap_ll3" value="" style="endArrow=none;dashed=1;dashPattern=5 4;strokeWidth=1;strokeColor=#888888;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="500" y="99" as="sourcePoint"/>
                        <mxPoint x="500" y="1070" as="targetPoint"/>
