        <mxCell id="ap_p3" value="DB&#xa;(SQL Server)"    style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="430"  y="55" width="120" height="44" as="geometry"/></mxCell>
        <mxCell id="ap_p4" value="MIME&#xa;Validator"     style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="620"  y="55" width="120" height="44" as="geometry"/></mxCell>
        <mxCell id="ap_p5" value="ClamAV&#xa;(TCP Daemon)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="810"  y="55" width="120" height="44" as="geometry"/></mxCell>
        <mxCell id="ap_p6" value="AES-256&#xa;Service"    style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="1000" y="55" width="120" height="44" as="geometry"/></mxCell>
        <mxCell id="ap_p7" value="MinIO&#xa;(Storage)"    style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#000000;strokeWidth=1.5;fontStyle=1;fontSize=12;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="1190" y="55" width="120" height="44" as="geometry"/></mxCell>
